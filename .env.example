ZAI_API_KEY=your-zai-api-key-here   # Get from https://open.bigmodel.cn/
MODEL_NAME=glm-4.5-air               # Options: glm-4.5-air, glm-4.5, glm-4.6, glm-4.7, glm-5, glm-5-tbo, glm-5.1
HEADLESS=true                        # true=no browser window, false=visible browser
TEMPERATURE=0.1                      # 0.0=deterministic, 1.0=creative
MAX_ACTIONS_PER_STEP=10              # Max actions per agent step
MAX_STEPS=20                         # Max steps for agent execution
OUTPUT_FILE=result.json              # Output file for results (empty to disable)

# Comma-separated allowed domains (empty = no restriction)
# Example: ALLOWED_DOMAINS=google.com,wikipedia.org
ALLOWED_DOMAINS=

# Max times agent can visit the same domain (loop guard)
MAX_VISITS_PER_DOMAIN=5

# Enable vision (screenshot) mode — requires a vision-capable model like glm-4v-flash
# Set MODEL_NAME=glm-4v-flash when enabling this
ENABLE_VISION=false

# Allow agent to request human input when blocked (requires browser-use >= 0.13)
# Note: browser-use 0.12.6 does not support built-in ask_human functionality
ENABLE_HUMAN_INPUT=false
