ZAI_API_KEY=your-zai-api-key-here   # Get from https://open.bigmodel.cn/
MODEL_NAME=glm-4-flash               # Options: glm-4-flash, glm-4-air, glm-4
HEADLESS=true                        # true=no browser window, false=visible browser
MAX_TOKENS=2000                      # Max tokens per LLM response
TEMPERATURE=0.1                      # 0.0=deterministic, 1.0=creative
